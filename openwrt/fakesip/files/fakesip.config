config fakesip 'main'
	option enabled '0'

	# Prefer logical OpenWrt network names. The init script resolves them to
	# Linux devices such as pppoe-wan, eth1, or wan.
	list network 'wan'

	# Use list interface when you already know the Linux device name.
	# list interface 'pppoe-wan'

	option all_interfaces '0'
	option inbound '0'
	option outbound '1'
	option ipv4 '1'
	option ipv6 '1'

	option queue_num '513'
	option fwmark '0x10000'
	option fwmask '0x10000'
	option repeat '2'
	option ttl '3'
	option dynamic_pct '0'

	option no_hop_estimate '0'
	option skip_firewall '0'
	option use_iptables '0'
	option silent '0'
	option log_file '/tmp/fakesip.log'

	# Optional payload settings. Multiple values are allowed.
	# list sip_uri 'sip:10086@example.com'
	# list payload_file '/etc/fakesip/payload.bin'
